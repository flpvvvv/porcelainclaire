NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
REVALIDATION_SECRET=your-revalidation-secret

# Optional: used by `sync/` CLI (`uv run sync article`, `backfill-tags`) for Gemini auto-tagging.
# Not read by the Next.js app. Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Sync CLI also loads the following when present (same files as above — run `uv run sync` from `sync/`).
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key
